# ── KIS Open API 인증 ─────────────────────────────────────────
# https://apiportal.koreainvestment.com 에서 AppKey / AppSecret 발급
KIS_APP_KEY=PSxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KIS_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# real: 실전투자 / demo: 모의투자
KIS_ENV=real

# API Base URL (기본값 사용 시 변경 불필요)
KIS_URL_BASE=https://openapi.koreainvestment.com:9443
KIS_URL_BASE_DEMO=https://openapivts.koreainvestment.com:29443

# ── 대상 ETF (Phase 1) ────────────────────────────────────────
TARGET_ETF_CODE=102110
TARGET_ETF_NAME=TIGER 200

# ── MySQL (2단계 이후 사용) ───────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=etf_user
DB_PASS=your_password
DB_NAME=etf_rebalance

# ── NAV ETL (3단계) ───────────────────────────────────────────
# 백필 시작일 (최소 2년치: 2024-06 ~ 현재)
NAV_BACKFILL_START_DATE=20240601