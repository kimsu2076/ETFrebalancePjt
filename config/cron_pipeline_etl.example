# NAV + Holdings 통합 ETL 일일 cron 예시 (5단계)
# 설치: crontab -e 후 아래 한 줄 추가
#
# 매일 18:35 KST (장 마감 후) NAV 증분 + Holdings 증분
35 18 * * 1-5 cd /home/smt14/ETFrebalancePjt && /home/smt14/pywork/.venv/bin/python scripts/etl_pipeline.py --nav-mode incremental --holdings-mode incremental >> /home/smt14/ETFrebalancePjt/logs/cron_etl_pipeline.log 2>&1